{
  "name": "Rain Effect",
  "version": "3.2.0",
  "sdkVersion": "2.17.1",
  "renderMode": "native",
  "entry": "index.js",
  "description": "Beautiful rain effect with realistic droplets and customizable settings",
  "author": "MyWallpaper Team",
  "license": "MIT",
  "keywords": [
    "rain",
    "weather",
    "effect",
    "ambient",
    "relaxing"
  ],
  "categories": [
    "effects",
    "weather",
    "ambient"
  ],
  "capabilities": {
    "hotReload": true,
    "systemEvents": [
      "viewport:resize",
      "theme:change"
    ]
  },
  "settings": {
    "rainSection": {
      "type": "section",
      "label": "Rain Settings"
    },
    "rainColor": {
      "type": "color",
      "label": "Rain Color",
      "description": "Color of the raindrops",
      "default": "#a8c8e8"
    },
    "rainIntensity": {
      "type": "range",
      "label": "Rain Intensity",
      "description": "Number of raindrops (WebGPU accelerated)",
      "min": 100,
      "max": 50000,
      "step": 100,
      "default": 200
    },
    "rainSpeed": {
      "type": "range",
      "label": "Fall Speed",
      "description": "How fast the rain falls",
      "min": 0.5,
      "max": 3,
      "step": 0.1,
      "default": 1.7
    },
    "dropLength": {
      "type": "range",
      "label": "Drop Length",
      "description": "Length of rain streaks",
      "min": 5,
      "max": 50,
      "step": 1,
      "default": 42
    },
    "dropWidth": {
      "type": "range",
      "label": "Drop Width",
      "description": "Thickness of raindrops",
      "min": 0.5,
      "max": 4,
      "step": 0.1,
      "default": 0.8
    },
    "windSection": {
      "type": "section",
      "label": "Wind & Direction"
    },
    "windAngle": {
      "type": "range",
      "label": "Wind Angle",
      "description": "Angle of rain (-45 to 45 degrees)",
      "min": -45,
      "max": 45,
      "step": 1,
      "default": -5
    },
    "windVariation": {
      "type": "range",
      "label": "Wind Variation",
      "description": "Random variation in wind",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 0
    },
    "effectsSection": {
      "type": "section",
      "label": "Visual Effects"
    },
    "opacity": {
      "type": "range",
      "label": "Opacity",
      "description": "Transparency of raindrops",
      "min": 0.1,
      "max": 1,
      "step": 0.05,
      "default": 0.6
    },
    "enableGlow": {
      "type": "boolean",
      "label": "Enable Glow",
      "description": "Add a soft glow effect to raindrops",
      "default": true
    },
    "glowIntensity": {
      "type": "range",
      "label": "Glow Intensity",
      "description": "Brightness of the glow effect",
      "min": 0.1,
      "max": 1,
      "step": 0.05,
      "default": 0.3
    }
  },
  "defaultLayout": {
    "xPercent": 0,
    "yPercent": 0,
    "widthPercent": 100,
    "heightPercent": 100
  },
  "ui": {
    "pointerEvents": "none"
  }
}